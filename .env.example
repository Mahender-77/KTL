# =============================================================================
# KTL Mobile (Expo) — copy to `.env` in this folder
# Variables must be prefixed with EXPO_PUBLIC_ to be available in the app.
# Restart Expo after changing env (clear cache if needed: npx expo start -c).
# =============================================================================

# API base URL (no trailing slash). Required for release builds.
# Development: if unset, falls back to http://localhost:5000 (simulators only).
#
# For a physical device, use your machine's LAN URL from the same network, e.g.:
#   EXPO_PUBLIC_API_URL=http://YOUR_HOSTNAME:5000
#
# Android emulator: often http://10.0.2.2:5000
# iOS simulator: http://localhost:5000
#
EXPO_PUBLIC_API_URL=http://localhost:5000

{
  "expo": {
    "name": "Ktl",
    "slug": "Ktl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/dhukanamTrans.png",
    "scheme": "ktl",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "KTL needs your location to find your delivery address.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "KTL needs your location to find your delivery address.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/dhukanamTrans.png",
        "monochromeImage": "./assets/images/dhukanamTrans.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "firebaseAppId": "1:609018009950:android:90792fb41093d5dce017cf",
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.ktl.app123"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/dhukanamTrans.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dhukanamTrans.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow KTL to use your location to find your delivery address."
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "expo-font",
      "expo-image",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a0e283f-6553-46a8-b541-c91d288c0935"
      }
    },
    "owner": "mahi-77"
  }
}
